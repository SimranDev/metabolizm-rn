# Backend base URL (no /v1). Leave empty for simulators — the app defaults to
# http://localhost:3000 (iOS) / http://10.0.2.2:3000 (Android emulator). Set to
# http://<your-lan-ip>:3000 when running on a physical device.
EXPO_PUBLIC_API_URL=

# Google sign-in (optional — the button shows a clear error when unset).
# WEB OAuth client id from Google Cloud; must match the api's GOOGLE_CLIENT_ID.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
# iOS OAuth client id; its reversed form also goes into app.json →
# @react-native-google-signin/google-signin → iosUrlScheme.
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=

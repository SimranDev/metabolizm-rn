{
  "expo": {
    "name": "Metabolizm",
    "slug": "metabolizm",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "metabolizmrn",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon",
      "bundleIdentifier": "com.metabolizm.app",
      "usesAppleSignIn": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FAFBF9",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.metabolizm.app"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "./plugins/with-workmanager-fix",
      "./plugins/with-auth-backup-rules",
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#1C5279",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 76,
          "dark": {
            "backgroundColor": "#0C1211"
          }
        }
      ],
      "expo-status-bar",
      "expo-secure-store",
      "expo-apple-authentication",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.REPLACE_WITH_IOS_CLIENT_ID"
        }
      ],
      [
        "expo-widgets",
        {
          "widgets": [
            {
              "name": "CaloriePace",
              "displayName": "Calories · Day pace",
              "description": "Calories remaining and your pace through the day.",
              "supportedFamilies": [
                "systemSmall",
                "systemMedium"
              ],
              "contentMarginsDisabled": false
            },
            {
              "name": "MacroBars",
              "displayName": "Macros",
              "description": "Today's carbs, fat and protein progress.",
              "supportedFamilies": [
                "systemSmall",
                "systemMedium"
              ],
              "contentMarginsDisabled": false
            },
            {
              "name": "PlateRing",
              "displayName": "Plate",
              "description": "Calories left on your plate with the macro split.",
              "supportedFamilies": [
                "systemSmall"
              ],
              "contentMarginsDisabled": false
            }
          ]
        }
      ],
      [
        "react-native-android-widget",
        {
          "widgets": [
            {
              "name": "CaloriePace",
              "label": "Calories · Day pace",
              "description": "Calories remaining and your pace through the day.",
              "minWidth": "110dp",
              "minHeight": "110dp",
              "targetCellWidth": 2,
              "targetCellHeight": 2,
              "resizeMode": "horizontal|vertical",
              "updatePeriodMillis": 1800000
            },
            {
              "name": "MacroBars",
              "label": "Macros",
              "description": "Today's carbs, fat and protein progress.",
              "minWidth": "110dp",
              "minHeight": "110dp",
              "targetCellWidth": 2,
              "targetCellHeight": 2,
              "resizeMode": "horizontal|vertical",
              "updatePeriodMillis": 1800000
            },
            {
              "name": "PlateRing",
              "label": "Plate",
              "description": "Calories left on your plate with the macro split.",
              "minWidth": "110dp",
              "minHeight": "110dp",
              "targetCellWidth": 2,
              "targetCellHeight": 2,
              "resizeMode": "none",
              "updatePeriodMillis": 1800000
            }
          ]
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "buildArchs": ["arm64-v8a", "armeabi-v7a"],
            "enableMinifyInReleaseBuilds": true,
            "enableShrinkResourcesInReleaseBuilds": true
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "build": {
          "experimental": {
            "ios": {
              "appExtensions": [
                {
                  "targetName": "ExpoWidgetsTarget",
                  "bundleIdentifier": "com.metabolizm.app.ExpoWidgetsTarget",
                  "entitlements": {
                    "com.apple.security.application-groups": [
                      "group.com.metabolizm.app"
                    ]
                  }
                }
              ]
            }
          }
        },
        "projectId": "ee145436-9700-49c4-b59c-cbeefa75f747"
      }
    },
    "owner": "simarexpo"
  }
}

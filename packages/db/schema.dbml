enum base_unit {
  g
  ml
}

enum food_source {
  system
  custom
}

enum group_category {
  partner
  family
  friends
  trainer
}

enum group_interaction_kind {
  comment
  reaction
}

enum group_member_status {
  invited
  active
  left
  removed
}

enum group_role {
  owner
  admin
  member
  coach
}

enum meal {
  breakfast
  lunch
  dinner
  snack
}

enum visibility {
  private
  public
}

table accounts {
  id uuid [pk, not null, default: `gen_random_uuid()`]
  user_id uuid [not null]
  account_id text [not null]
  provider_id text [not null]
  access_token text
  refresh_token text
  id_token text
  access_token_expires_at "timestamp with time zone"
  refresh_token_expires_at "timestamp with time zone"
  scope text
  password text
  created_at "timestamp with time zone" [not null, default: `now()`]
  updated_at "timestamp with time zone" [not null, default: `now()`]

  indexes {
    user_id [name: 'accounts_user_id_idx']
    (provider_id, account_id) [name: 'accounts_provider_account_uq', unique]
  }
}

table daily_summaries {
  user_id uuid [not null]
  entry_date date [not null]
  energy_kcal "numeric(10, 2)" [not null, default: 0]
  protein_g "numeric(10, 2)" [not null, default: 0]
  carbs_g "numeric(10, 2)" [not null, default: 0]
  fat_g "numeric(10, 2)" [not null, default: 0]
  meals_logged integer [not null, default: 0]
  meal_names jsonb [not null, default: `[]`]
  target_kcal "numeric(8, 2)"
  target_protein_g "numeric(8, 2)"
  target_carbs_g "numeric(8, 2)"
  target_fat_g "numeric(8, 2)"
  weight_kg "numeric(6, 2)"
  updated_at "timestamp with time zone" [not null, default: `now()`]

  indexes {
    (user_id, entry_date) [pk]
  }
}

table diary_entries {
  id uuid [pk, not null, default: `gen_random_uuid()`]
  user_id uuid [not null]
  entry_date date [not null]
  meal meal [not null]
  food_id uuid
  name text [not null]
  serving_label text [not null]
  quantity "numeric(8, 3)"
  unit_label text
  unit_amount_in_base "numeric(10, 3)"
  energy_kcal "numeric(8, 2)" [not null]
  protein_g "numeric(8, 2)" [not null]
  carbs_g "numeric(8, 2)" [not null]
  fat_g "numeric(8, 2)" [not null]
  nutrients jsonb [not null, default: `{}`]
  verified boolean [not null, default: false]
  logged_at "timestamp with time zone" [not null, default: `now()`]
  version bigint [not null, default: 1]
  created_at "timestamp with time zone" [not null, default: `now()`]
  updated_at "timestamp with time zone" [not null, default: `now()`]
  deleted_at "timestamp with time zone"

  indexes {
    (user_id, entry_date) [name: 'diary_entries_user_date_idx']
    (user_id, updated_at, id) [name: 'diary_entries_user_updated_idx']
  }
}

table food_portions {
  id uuid [pk, not null, default: `gen_random_uuid()`]
  food_id uuid [not null]
  label text [not null]
  quantity "numeric(8, 3)" [not null, default: 1]
  amount_in_base "numeric(10, 3)" [not null]
  is_default boolean [not null, default: false]

  indexes {
    food_id [name: 'food_portions_food_id_idx']
  }
}

table foods {
  id uuid [pk, not null, default: `gen_random_uuid()`]
  owner_id uuid
  name text [not null]
  brand text
  description text
  barcode text
  source_ref text
  source food_source [not null, default: 'custom']
  base_unit base_unit [not null, default: 'g']
  serving_size "numeric(8, 2)" [not null, default: 100]
  serving_label text
  energy_kcal "numeric(8, 2)" [not null]
  protein_g "numeric(8, 2)" [not null]
  carbs_g "numeric(8, 2)" [not null]
  fat_g "numeric(8, 2)" [not null]
  nutrients jsonb [not null, default: `{}`]
  visibility visibility [not null, default: 'private']
  is_verified boolean [not null, default: false]
  popularity integer [not null, default: 0]
  forked_from uuid
  version bigint [not null, default: 1]
  created_at "timestamp with time zone" [not null, default: `now()`]
  updated_at "timestamp with time zone" [not null, default: `now()`]
  deleted_at "timestamp with time zone"

  indexes {
    owner_id [name: 'foods_owner_id_idx']
    name [name: 'foods_name_trgm_idx']
    barcode [name: 'foods_barcode_active_uq', unique]
    source_ref [name: 'foods_source_ref_active_uq', unique]
  }
}

table group_interactions {
  id uuid [pk, not null, default: `gen_random_uuid()`]
  group_id uuid [not null]
  author_id uuid [not null]
  subject_user_id uuid [not null]
  subject_date date [not null]
  kind group_interaction_kind [not null]
  body text
  emoji text
  created_at "timestamp with time zone" [not null, default: `now()`]
  deleted_at "timestamp with time zone"

  indexes {
    (group_id, subject_user_id, subject_date) [name: 'group_interactions_subject_idx']
    (group_id, author_id, subject_user_id, subject_date, emoji) [name: 'group_interactions_reaction_uq', unique]
  }
}

table group_invites {
  id uuid [pk, not null, default: `gen_random_uuid()`]
  group_id uuid [not null]
  created_by uuid [not null]
  token text [not null]
  expires_at "timestamp with time zone" [not null]
  max_uses integer
  use_count integer [not null, default: 0]
  revoked_at "timestamp with time zone"
  created_at "timestamp with time zone" [not null, default: `now()`]

  indexes {
    token [name: 'group_invites_token_uq', unique]
    group_id [name: 'group_invites_group_id_idx']
  }
}

table group_members {
  id uuid [pk, not null, default: `gen_random_uuid()`]
  group_id uuid [not null]
  user_id uuid [not null]
  role group_role [not null, default: 'member']
  status group_member_status [not null, default: 'active']
  share_config jsonb [not null, default: `{}`]
  last_seen_at "timestamp with time zone"
  joined_at "timestamp with time zone" [not null, default: `now()`]
  left_at "timestamp with time zone"

  indexes {
    (group_id, user_id) [name: 'group_members_group_user_current_uq', unique]
    user_id [name: 'group_members_user_id_idx']
  }
}

table groups {
  id uuid [pk, not null, default: `gen_random_uuid()`]
  name text [not null]
  category group_category [not null]
  owner_id uuid [not null]
  created_at "timestamp with time zone" [not null, default: `now()`]
  updated_at "timestamp with time zone" [not null, default: `now()`]
  deleted_at "timestamp with time zone"

  indexes {
    owner_id [name: 'groups_owner_id_idx']
  }
}

table sessions {
  id uuid [pk, not null, default: `gen_random_uuid()`]
  user_id uuid [not null]
  token text [not null]
  expires_at "timestamp with time zone" [not null]
  ip_address text
  user_agent text
  created_at "timestamp with time zone" [not null, default: `now()`]
  updated_at "timestamp with time zone" [not null, default: `now()`]

  indexes {
    user_id [name: 'sessions_user_id_idx']
    token [name: 'sessions_token_uq', unique]
  }
}

table user_targets {
  id uuid [pk, not null, default: `gen_random_uuid()`]
  user_id uuid [not null]
  effective_from date [not null]
  energy_kcal "numeric(8, 2)" [not null]
  protein_g "numeric(8, 2)" [not null]
  carbs_g "numeric(8, 2)" [not null]
  fat_g "numeric(8, 2)" [not null]
  set_by uuid
  created_at "timestamp with time zone" [not null, default: `now()`]

  indexes {
    (user_id, effective_from) [name: 'user_targets_user_effective_idx']
  }
}

table users {
  id uuid [pk, not null, default: `gen_random_uuid()`]
  email text [not null, unique]
  name text [not null]
  email_verified boolean [not null, default: false]
  image text
  timezone text [not null, default: 'UTC']
  created_at "timestamp with time zone" [not null, default: `now()`]
  updated_at "timestamp with time zone" [not null, default: `now()`]
}

table verifications {
  id uuid [pk, not null, default: `gen_random_uuid()`]
  identifier text [not null]
  value text [not null]
  expires_at "timestamp with time zone" [not null]
  created_at "timestamp with time zone" [not null, default: `now()`]
  updated_at "timestamp with time zone" [not null, default: `now()`]

  indexes {
    identifier [name: 'verifications_identifier_idx']
  }
}

ref accounts_user_id_users_id_fk: accounts.user_id > users.id [delete: cascade, update: no action]

ref daily_summaries_user_id_users_id_fk: daily_summaries.user_id > users.id [delete: cascade, update: no action]

ref diary_entries_user_id_users_id_fk: diary_entries.user_id > users.id [delete: cascade, update: no action]

ref diary_entries_food_id_foods_id_fk: diary_entries.food_id > foods.id [delete: set null, update: no action]

ref food_portions_food_id_foods_id_fk: food_portions.food_id > foods.id [delete: cascade, update: no action]

ref foods_owner_id_users_id_fk: foods.owner_id > users.id [delete: cascade, update: no action]

ref foods_forked_from_foods_id_fk: foods.forked_from > foods.id [delete: set null, update: no action]

ref group_interactions_group_id_groups_id_fk: group_interactions.group_id > groups.id [delete: cascade, update: no action]

ref group_interactions_author_id_users_id_fk: group_interactions.author_id > users.id [delete: cascade, update: no action]

ref group_interactions_subject_user_id_users_id_fk: group_interactions.subject_user_id > users.id [delete: cascade, update: no action]

ref group_invites_group_id_groups_id_fk: group_invites.group_id > groups.id [delete: cascade, update: no action]

ref group_invites_created_by_users_id_fk: group_invites.created_by > users.id [delete: cascade, update: no action]

ref group_members_group_id_groups_id_fk: group_members.group_id > groups.id [delete: cascade, update: no action]

ref group_members_user_id_users_id_fk: group_members.user_id > users.id [delete: cascade, update: no action]

ref groups_owner_id_users_id_fk: groups.owner_id > users.id [delete: restrict, update: no action]

ref sessions_user_id_users_id_fk: sessions.user_id > users.id [delete: cascade, update: no action]

ref user_targets_user_id_users_id_fk: user_targets.user_id > users.id [delete: cascade, update: no action]

ref user_targets_set_by_users_id_fk: user_targets.set_by > users.id [delete: set null, update: no action]